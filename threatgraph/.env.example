# Copy to .env and fill in to activate production backends / integrations.
# Everything works offline with these UNSET (in-memory graph + stub integrations).

# --- Module 2: Neo4j graph backend ---
# Set NEO4J_URI to switch from the in-memory NetworkX graph to Neo4j.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=threatgraph

# --- Module 1: streaming ingestion ---
# KAFKA_BROKER=localhost:9092

# --- Module 3: alerting integrations ---
# SIEM_WEBHOOK=https://your-siem/api/ingest
# THEHIVE_URL=https://thehive.local
# THEHIVE_KEY=your-api-key
# GRAFANA_PUSH_URL=https://your-pushgateway/metrics/job/threatgraph

# --- Module 4: dark-web / CTI enrichment ---
# OPENCTI_URL=https://opencti.local
# OPENCTI_TOKEN=your-token